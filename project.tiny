develop:
  actions:
    - name: dev
      description: 启动 daemon 开发环境
      command: VOXSPELL_DETERMINISTIC=1 VOXSPELL_DICTIONARY_PATH=../../configs/dictionary.yaml yarn --cwd apps/daemon rspack build --env watch=true,run=true,debug=true
      actions:
        - name: asr
          description: 使用 config.yaml 中的真实 ASR Provider 启动 daemon 开发环境
          command: VOXSPELL_CONFIG_PATH=../../configs/config.yaml VOXSPELL_DICTIONARY_PATH=../../configs/dictionary.yaml yarn --cwd apps/daemon rspack build --env watch=true,run=true,debug=true
    - name: start
      description: 运行已构建的 daemon bundle
      command: yarn --cwd apps/daemon node --enable-source-maps dist/index.cjs
    - name: integration
      description: 安装 Fcitx addon 并启动确定性 daemon 联调完整输入流程
      command:
        - yarn tiny install-fcitx5-addon
        - yarn tiny dev
      actions:
        - name: tencent
          description: 安装 Fcitx addon 并启动腾讯云实时 ASR 联调
          command:
            - yarn tiny install-fcitx5-addon
            - VOXSPELL_ASR_PROVIDER=tencent yarn tiny dev/asr
        - name: openrouter
          description: 安装 Fcitx addon 并启动 OpenRouter ASR 联调
          command:
            - yarn tiny install-fcitx5-addon
            - VOXSPELL_ASR_PROVIDER=openrouter yarn tiny dev/asr
        - name: glm
          description: 安装 Fcitx addon 并启动 GLM ASR 联调
          command:
            - yarn tiny install-fcitx5-addon
            - VOXSPELL_ASR_PROVIDER=glm yarn tiny dev/asr
    - name: desktop
      description: 构建并启动 GTK 桌面配置应用
      command:
        - yarn tiny build/desktop
        - yarn --cwd apps/desktop node --enable-source-maps dist/index.cjs
    - name: mock-daemon
      description: 启动供 C++ 扩展联调的延迟测试 daemon
      command: node native/fcitx5-addon/test/mock-daemon/mock-daemon.mjs
    - name: install-fcitx5-addon
      description: 构建、安装并重启 Fcitx 5 C++ 扩展
      command:
        - yarn tiny build/fcitx5-addon
        - cmake --install dist/native/fcitx5-addon --prefix $HOME/.local
        - fcitx5 -r -d
    - name: test
      description: 执行单元测试
      command:
        - yarn --cwd packages/protocol vitest run
        - yarn --cwd packages/asr-core vitest run
        - yarn --cwd packages/ai-polisher vitest run
        - yarn --cwd packages/config vitest run
        - yarn --cwd packages/asr-openai-compatible vitest run
        - yarn --cwd packages/asr-tencent vitest run
        - yarn --cwd packages/text-pipeline vitest run
        - yarn --cwd apps/daemon vitest run
        - yarn --cwd apps/desktop vitest run
      actions:
        - name: fcitx5-addon
          description: 执行 Fcitx 5 C++ 扩展测试
          command:
            - yarn tiny build/fcitx5-addon
            - ctest --test-dir dist/native/fcitx5-addon --output-on-failure
    - name: smoke
      description: 使用真实 Unix Socket 验证 daemon 闭环
      command: yarn --cwd apps/daemon vitest run test/daemon-runtime.test.ts
      actions:
        - name: asr-fixtures
          description: 使用固定 fixtures 请求真实 ASR Provider
          command:
            - yarn --cwd apps/daemon rspack build
            - VOXSPELL_CONFIG_PATH=../../configs/config.yaml yarn --cwd apps/daemon node --enable-source-maps dist/asr-fixtures-smoke.cjs
        - name: asr-microphone
          description: 录制麦克风并显示真实 ASR Provider 的实时识别结果
          command:
            - yarn --cwd apps/daemon rspack build
            - VOXSPELL_CONFIG_PATH=../../configs/config.yaml yarn --cwd apps/daemon node --enable-source-maps dist/asr-microphone-smoke.cjs
        - name: asr-tencent
          description: 使用腾讯云实时 ASR 录制麦克风并显示实时结果
          command:
            - yarn --cwd apps/daemon rspack build
            - VOXSPELL_ASR_PROVIDER=tencent VOXSPELL_CONFIG_PATH=../../configs/config.yaml yarn --cwd apps/daemon node --enable-source-maps dist/asr-microphone-smoke.cjs
    - name: audio-smoke
      description: 录制麦克风并显示实时音量
      command:
        - yarn --cwd apps/daemon rspack build
        - yarn --cwd apps/daemon node --enable-source-maps dist/audio-smoke.cjs
    - name: typecheck
      description: 执行 TypeScript 类型检查
      command:
        - yarn --cwd packages/protocol tsc --noEmit
        - yarn --cwd packages/asr-core tsc --noEmit
        - yarn --cwd packages/ai-polisher tsc --noEmit
        - yarn --cwd packages/config tsc --noEmit
        - yarn --cwd packages/asr-openai-compatible tsc --noEmit
        - yarn --cwd packages/asr-tencent tsc --noEmit
        - yarn --cwd packages/text-pipeline tsc --noEmit
        - yarn --cwd apps/daemon tsc --noEmit
        - yarn --cwd apps/desktop tsc --noEmit
    - name: lint
      description: 使用 Oxlint 执行静态代码分析
      command: yarn oxlint -c oxlint.config.mts -f stylish apps packages
      actions:
        - name: fix
          description: 自动修复 Oxlint 问题
          command: yarn oxlint -c oxlint.config.mts -f stylish apps packages --fix
    - name: format
      description: 使用 Oxfmt 格式化代码
      command: yarn oxfmt apps packages
      actions:
        - name: check
          description: 检查代码格式
          command: yarn oxfmt --check apps packages
    - name: fix-worktree
      description: 规范化工作区
      tooltip: 只处理未暂存的新增和修改文件
      command: yarn tiny hooks run fix-worktree

publish:
  actions:
    - name: build
      description: 构建 daemon bundle
      command: yarn --cwd apps/daemon rspack build
      actions:
        - name: desktop
          description: 生成 GTK 类型并构建桌面应用
          command:
            - yarn --cwd apps/desktop node-gtk generate-types Gtk-4.0 Adw-1 --outdir .cache/types
            - yarn --cwd apps/desktop rspack build
        - name: fcitx5-addon
          description: 构建 Fcitx 5 C++ 扩展
          command:
            - cmake -S native/fcitx5-addon -B dist/native/fcitx5-addon -G Ninja -DCMAKE_BUILD_TYPE=RelWithDebInfo
            - cmake --build dist/native/fcitx5-addon
    - name: linux
      description: 构建并发布通用 Linux x86_64 二进制资产
      command: node scripts/release-linux.mts publish
      actions:
        - name: build
          description: 仅构建通用 Linux x86_64 二进制资产，不执行外部发布
          command: node scripts/release-linux.mts build
    - name: aur
      description: 基于通用 Linux 二进制资产发布 GitHub Release 与 AUR
      command:
        - node scripts/release-linux.mts publish
        - node scripts/release-aur.mts publish
      actions:
        - name: build
          description: 基于通用 Linux 二进制资产构建 pacman 安装包与 AUR 元数据
          command:
            - node scripts/release-linux.mts build
            - node scripts/release-aur.mts build

tools:
  actions:
    - name: version
      description: 更新所有包和 Fcitx addon 的版本号
      command: node scripts/update-version.mts
    - name: clean
      description: 清理所有 dist 目录和用户目录安装的 Fcitx C++ 扩展
      command:
        - node scripts/clean.mts
        - fcitx5 -r -d
    - name: 文档
      description: 启动文档预览
      command: yarn tiny-docs -c docs/configs.yaml serve -o
      actions:
        - name: 构建
          description: 生成静态文档
          command:
          - yarn tiny-docs -c docs/configs.yaml publish dist/docs
          - yarn http-server dist/docs -c-1 -o

variables:
  allTsHookFiles: &all_ts_hook_files
    include:
      - "*.{ts,tsx,mts,cts}"
      - "apps/**/*.{ts,tsx,mts,cts}"
      - "packages/**/*.{ts,tsx,mts,cts}"
    exclude:
      - "**/*.d.ts"

hooks:
  fix-worktree:
    - name: oxlint
      command: yarn oxlint -c oxlint.config.mts -f stylish --fix
      files:
        <<: *all_ts_hook_files
        source: changed
    - name: oxfmt
      command: yarn oxfmt
      files:
        <<: *all_ts_hook_files
        source: changed
