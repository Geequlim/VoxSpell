root = true

[*]
indent_style = tab
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[{*.yaml,*.yml,*.tiny,*.yaml.txt}]
indent_style = space
indent_size = 2

[{*.svelte,*.html,*.xml,*.svg,*.hbs,*.handlebars}]
indent_style = tab
indent_size = 2
